# Discord Bot Token（Discord Developer Portalで取得）
DISCORD_TOKEN=your-token-here

# あなたのDiscord User ID（開発者モードでコピー）
OWNER_ID=your-discord-user-id-here

# Bot設定（変更不要）
BOT_PREFIX=!
CLAUDE_TIMEOUT=120
LOG_LEVEL=INFO

# 定期報告送信先チャンネルID（0=DMにフォールバック）
REPORT_CHANNEL_ID=0

# Claude Code CLI認証トークン（launchd環境で必要）
CLAUDE_OAUTH_TOKEN=

# X (Twitter) API設定（Lex Ventures用 / Free tier: 月500投稿）
# X Developer Portalで取得: https://developer.x.com/
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=
